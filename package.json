{
  "name": "save-my-session",
  "version": "0.5.1",
  "description": "Transfer coding sessions between AI agents (Claude Code, Gemini CLI, Codex)",
  "main": "dist/cli.js",
  "bin": {
    "save-my-session": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/prompts dist/prompts",
    "dev": "ts-node src/cli.ts",
    "test": "vitest run",
    "preuninstall": "save-my-session uninstall || true"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "session",
    "handoff",
    "claude-code",
    "gemini-cli",
    "codex"
  ],
  "author": "guggg",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
